# Core environment
export PATH=$HOME/bin:/usr/local/bin:$PATH
export ZSH="$HOME/.oh-my-zsh"
export LANG=en_GB.UTF-8
export MANPATH="/usr/local/man:$MANPATH"
export EDITOR="nvim"
export HOST="$(hostname)"
export DOTFILES_PATH="${HOME}/.dotfiles"
export DOTFILES_ZSH_PATH="${DOTFILES_PATH}/zsh"

# Personal scripts live in dotfiles/bin
export PATH="${DOTFILES_PATH}/bin:$PATH"

# Early out for IntelliJ IDEs
if [ ! -z "$INTELLIJ_ENVIRONMENT_READER" ]; then
	echo "I am in IntelliJ, exiting before zsh setup"
	return
fi

# Oh My Zsh configuration
HYPHEN_INSENSITIVE="true"
zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 13
ENABLE_CORRECTION="false"
COMPLETION_WAITING_DOTS="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"
HIST_STAMPS="dd/mm/yyyy"
ZSH_THEME="powerlevel10k/powerlevel10k"
plugins=(
	colored-man-pages 
	fzf-zsh-plugin 
	git 
	macos 
	ssh-agent 
	zsh-syntax-highlighting 
	zsh-vi-mode
)

# Homebrew must be configured before modules that depend on brew paths
source "${DOTFILES_ZSH_PATH}/settings/homebrew.zsh"

# SSH agent must be configured before OMZ is sourced
source "${DOTFILES_ZSH_PATH}/settings/ssh-agent.zsh"


# OH MY ZSH
source $ZSH/oh-my-zsh.sh

# Source all settings modules
for f in "${DOTFILES_ZSH_PATH}"/settings/*.zsh; do
	[[ "$(basename "$f")" == "ssh-agent.zsh" ]] && continue
	[[ "$(basename "$f")" == "homebrew.zsh" ]] && continue
	source "$f"
done

export PATH="$PATH:/Users/sherman/Library/Android/sdk/platform-tools"

# Source all alias/tool modules
for f in "${DOTFILES_ZSH_PATH}"/aliases/*.zsh; do
	source "$f"
done

# iTerm2 shell integration
test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"
export PATH="$PATH:$HOME/.dual-graph"

# Added by get-aspire-cli.sh
export PATH="$HOME/.aspire/bin:$PATH"

# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/sherman/.lmstudio/bin"
# End of LM Studio CLI section

export PATH="/opt/homebrew/opt/ruby/bin:$PATH"

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# direnv hook
eval "$(direnv hook zsh)"
